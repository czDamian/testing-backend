# Application
APP_ENV=development
APP_PORT=8000

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL="claude-haiku-4-5" # or any model of your choice

# Supabase — Settings → API in your Supabase dashboard
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase — Settings → Database in your Supabase dashboard
SUPABASE_DATABASE_URL=postgres://postgres:[PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Use the service role key (not anon key) to bypass RLS for server-side ops.
# NEVER expose this to a frontend client.

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456789:ABCDEF...
# Get this from @BotFather

# Chat session TTL in seconds (30 minutes)
SESSION_TTL=1800
